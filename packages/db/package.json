{
  "name": "@tabletop/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"db: no tests yet\"",
    "prisma:generate": "node scripts/prisma.mjs generate --schema prisma/schema.prisma",
    "prisma:migrate": "node scripts/prisma.mjs migrate dev --schema prisma/schema.prisma",
    "prisma:push": "node scripts/prisma.mjs db push --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
